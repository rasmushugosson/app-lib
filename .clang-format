BasedOnStyle: LLVM

IndentWidth: 4
UseTab: Never
ColumnLimit: 120

# Braces on next line
BreakBeforeBraces: Allman

# Ex: int* a
PointerAlignment: Right

Cpp11BracedListStyle: false

# Includes: sort + group nicely
SortIncludes: true
IncludeBlocks: Regroup
IncludeCategories:
  - Regex: '^"(general/)?pch\.h"'
    Priority: -1 # PCH must be first
  - Regex: '^"'
    Priority: 0 # project / local headers
  - Regex: "^<glad/"
    Priority: 1 # GLAD must come before GLFW
  - Regex: '^<vulkan/vulkan\.h>'
    Priority: 2 # vulkan.h must precede VMA
  - Regex: "^<.*>"
    Priority: 3 # system / library headers

# No one-line control flow
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
AllowShortFunctionsOnASingleLine: Empty
